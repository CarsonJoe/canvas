{
  "name": "@cogniboom/canvas",
  "version": "0.2.2",
  "description": "Local Cogniboom Canvas app server and MCP helper.",
  "type": "module",
  "bin": {
    "canvas": "bin/canvas-mcp.js"
  },
  "exports": {
    "./server/app-server": "./server/canvas-app-server.mjs",
    "./server/document-store": "./server/canvas-local-core.mjs",
    "./server/mcp": "./server/canvas-mcp-server.mjs",
    "./server/tools": "./server/canvas-mcp-server.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "server/",
    "dist/",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "prepare": "node bin/build-dist.mjs",
    "pack:dry": "npm pack --dry-run",
    "postinstall": "node bin/canvas-mcp.js setup"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "canvas",
    "mcp",
    "model-context-protocol",
    "cogniboom"
  ],
  "license": "UNLICENSED"
}
