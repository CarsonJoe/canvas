{
  "name": "canvas-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:mcp-package": "npm run build && node scripts/prepare-canvas-mcp-package.mjs",
    "pack:mcp-package": "npm run build:mcp-package && node scripts/pack-canvas-mcp-package.mjs",
    "app": "npm run build && node -e \"process.env.CANVAS_MODE='app';eval(require('fs').readFileSync('scripts/canvas-local.cjs','utf8'))\"",
    "app:no-open": "npm run build && node -e \"process.env.CANVAS_MODE='app';process.env.CANVAS_NO_OPEN='1';eval(require('fs').readFileSync('scripts/canvas-local.cjs','utf8'))\"",
    "mcp": "node -e \"process.env.CANVAS_MODE='mcp';eval(require('fs').readFileSync('scripts/canvas-local.cjs','utf8'))\"",
    "dev:server": "node -e \"process.env.CANVAS_MODE='app';process.env.CANVAS_NO_OPEN='1';eval(require('fs').readFileSync('scripts/canvas-local.cjs','utf8'))\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "konva": "^9.3.6",
    "lucide-react": "^0.395.0",
    "marked": "^18.0.4",
    "mermaid": "^11.15.0",
    "nanoid": "^5.0.7",
    "openai": "^4.58.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-konva": "^18.2.10",
    "use-image": "^1.1.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^6.4.2"
  }
}
